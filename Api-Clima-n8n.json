      "parameters": {
        "jsCode": "const raw = $input.first().json.output;\n\n// Separar el reporte del bloque de datos\nconst dataMatch = raw.match(/%%DATA%%([\\s\\S]*?)%%END%%/);\nconst reporteHtml = raw.replace(/%%DATA%%[\\s\\S]*?%%END%%/, '').trim();\n\nlet datosClima = {\n  origin_temperature: null,\n  destination_temperature: null,\n  origin_condition: null,\n  destination_condition: null\n};\n\nif (dataMatch) {\n  datosClima = JSON.parse(dataMatch[1].trim());\n}\n\nreturn [{\n  json: {\n    output: reporteHtml,\n    origin_temperature: datosClima.origin_temperature,\n    destination_temperature: datosClima.destination_temperature,\n    origin_condition: datosClima.origin_condition,\n    destination_condition: datosClima.destination_condition\n  }\n}];\n"
