    {
      "parameters": {
        "jsCode": "let entrada = $input.all()[0].json;\n\nlet rawData = entrada.body || entrada.data || entrada;\n\nlet parsedData;\nif (typeof rawData === 'string') {\n    parsedData = JSON.parse(rawData);\n} else {\n    parsedData = rawData; \n}\n\nlet rutaCompleta = parsedData.features[0].geometry.coordinates;\n\nlet totalPuntos = rutaCompleta.length;\nlet saltos = Math.floor(totalPuntos / 4);\nlet puntosClima = [];\n\npuntosClima.push({\n  json: {\n    nombre: \"Origen\",\n    longitud: rutaCompleta[0][0], \n    latitud: rutaCompleta[0][1]  \n  }\n});\n\npuntosClima.push({\n  json: {\n    nombre: \"Intermedio 1\",\n    longitud: rutaCompleta[saltos][0], \n    latitud: rutaCompleta[saltos][1] \n  }\n});\n\npuntosClima.push({\n  json: {\n    nombre: \"Intermedio 2\",\n    longitud: rutaCompleta[saltos * 2][0],\n    latitud: rutaCompleta[saltos * 2][1] \n  }\n});\n\npuntosClima.push({\n  json: {\n    nombre: \"Intermedio 3\",\n    longitud: rutaCompleta[saltos * 3][0], \n    latitud: rutaCompleta[saltos * 3][1] \n  }\n});\n\npuntosClima.push({\n  json: {\n    nombre: \"Destino\",\n    longitud: rutaCompleta[totalPuntos - 1][0],\n    latitud: rutaCompleta[totalPuntos - 1][1] \n  }\n});\n\nreturn puntosClima;"
      },
